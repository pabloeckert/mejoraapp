# ── Supabase ──────────────────────────────────────────────────────
# URL del proyecto Supabase (obtener en: supabase.com > Project Settings > API)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co

# Publishable Key (anon key) — se usa en el frontend, es pública
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Project ID — para referencia en scripts
VITE_SUPABASE_PROJECT_ID=tu-project-id

# ── Analytics (PostHog) ──────────────────────────────────────────
# Opcional — sin esto, analytics se desactiva automáticamente
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ── Push Notifications (VAPID) ───────────────────────────────────
# Generar con: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=BNxxxxxxxxxxxxx

# ── Environment ──────────────────────────────────────────────────
# Valores: production | staging | development
VITE_ENVIRONMENT=development

# ── Sentry (Error Tracking) ──────────────────────────────────────
# Opcional — sin esto, Sentry se desactiva
VITE_SENTRY_DSN=https://xxx@sentry.io/xxx

# ── Debug ────────────────────────────────────────────────────────
# Forzar analytics en development (solo para debug)
VITE_ANALYTICS_DEBUG=false
