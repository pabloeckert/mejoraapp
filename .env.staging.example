# Staging Environment
# Copy this to .env.staging and fill in values from your staging Supabase project
# Run with: npm run build:staging

VITE_SUPABASE_URL=https://YOUR_STAGING_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-staging-anon-key
VITE_SUPABASE_PROJECT_ID=your-staging-project-id
VITE_ENVIRONMENT=staging

# Optional: Sentry DSN for staging
# VITE_SENTRY_DSN=https://your-sentry-dsn

# Optional: PostHog key for staging
# VITE_POSTHOG_KEY=phc_your_staging_key
